# Eino RAG Demo Configuration

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Embedding Configuration (OpenAI compatible)
EMBEDDING_API_KEY=your-api-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=100

# Rerank Configuration (OpenAI compatible)
RERANK_API_KEY=your-api-key-here
RERANK_MODEL=cohere-rerank
RERANK_BASE_URL=https://api.cohere.ai/v1
RERANK_TOP_N=10

# Vector Store Configuration (Qdrant)
VECTOR_STORE_URL=http://localhost:6334
VECTOR_STORE_API_KEY=your-qdrant-api-key
VECTOR_STORE_COLLECTION=knowledge_base
VECTOR_STORE_VECTOR_SIZE=1536
VECTOR_STORE_DISTANCE=Cosine

# LLM Configuration (for RAG answer generation)
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# RAG Configuration
RAG_TOP_K=5
RAG_RERANK_TOP_K=3
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
